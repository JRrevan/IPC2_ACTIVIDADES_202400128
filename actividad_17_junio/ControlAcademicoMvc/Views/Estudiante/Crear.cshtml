@model ControlAcademicoMvc.Models.Estudiante

@{
    ViewData["Title"] = "Crear Nuevo Estudiante";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <h1 class="mb-4">Crear Nuevo Estudiante</h1>

            <form asp-action="Crear" asp-controller="Estudiante" method="post" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label asp-for="Carne" class="form-label">Número de Carné</label>
                    <input asp-for="Carne" class="form-control" placeholder="Ej: 2020001" required />
                    <span asp-validation-for="Carne" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label">Nombre Completo</label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej: Juan García López" required />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Promedio" class="form-label">Promedio Académico</label>
                    <input asp-for="Promedio" type="number" step="0.01" min="0" max="4" 
                           class="form-control" placeholder="Ej: 3.75" required />
                    <small class="form-text text-muted">Ingrese un valor entre 0.00 y 4.00</small>
                    <span asp-validation-for="Promedio" class="text-danger"></span>
                </div>

                <div class="alert alert-warning" role="alert">
                    <strong>Nota:</strong> El sistema validará que el promedio esté dentro del rango permitido (0.0 - 4.0)
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle"></i> Crear Estudiante
                    </button>
                    <a href="@Url.Action("Index", "Estudiante")" class="btn btn-secondary">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
