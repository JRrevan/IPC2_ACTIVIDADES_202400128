@model List<ControlAcademicoMvc.Models.Estudiante>

@{
    ViewData["Title"] = "Listado de Estudiantes";
}

<div class="container mt-4">
    <h1 class="mb-4">Listado de Estudiantes</h1>

    <div class="mb-3">
        <a href="@Url.Action("Crear", "Estudiante")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo Estudiante
        </a>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Carné</th>
                    <th>Nombre</th>
                    <th>Promedio</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var estudiante in Model)
                {
                    <tr>
                        <td><strong>@estudiante.Carne</strong></td>
                        <td>@estudiante.Nombre</td>
                        <td>
                            <span class="badge @(estudiante.Promedio >= 3.5m ? "bg-success" : "bg-warning")">
                                @estudiante.Promedio.ToString("F2")
                            </span>
                        </td>
                        <td>
                            <a href="@Url.Action("Detalles", "Estudiante", new { id = estudiante.Carne })" 
                               class="btn btn-info btn-sm">
                                Ver
                            </a>
                            <form action="@Url.Action("Eliminar", "Estudiante")" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@estudiante.Carne" />
                                <button type="submit" class="btn btn-danger btn-sm" 
                                        onclick="return confirm('¿Está seguro?')">
                                    Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            No hay estudiantes registrados. <a href="@Url.Action("Crear", "Estudiante")">Crear uno ahora</a>
        </div>
    }
</div>
